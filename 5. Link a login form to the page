<!DOCTYPE html>
<html>
    <head>
        <title>FORM</title>
        <style>
            *{
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body{
    height: 100vh;
    background: linear-gradient(to left,#FF00D0,#05CDFF);
    display: flex;
    justify-content: center;    /* keeps form centered */
    align-items: center;
    position: relative;         /* allows absolute positioning */
}

/* HOME button in top-right */
.top-home-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    padding: 12px 25px;
    background: black;
    color: white;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
}

/* FORM container */
.container{
    width: 400px;
    height: 450px;
    background-color: #f9f9f9;
    border-radius: 30px;
    padding: 40px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
}

.container h1{
    margin-bottom: 40px;
    font-size: 30px;
    font-family: sans-serif;
}

.container form label{
    display: block;
    text-align: left;
    font-size: 18px;
    margin-bottom: 5px;
}

.container form input{
    width: 100%;
    border: none;
    border-bottom: 1px solid #000;
    padding: 10px 0;
    font-size: 17px;
    margin-bottom: 30px;
    background: transparent;
    outline: none;
}

.container form button{
    width: 100%;
    height: 50px;
    border-radius: 50px;
    background: linear-gradient(to right,#FF00D0,#05CDFF);
    border: none;
    font-size: 20px;
    font-weight: 800;
    color: white;
    cursor: pointer;
}
            
        </style>
    </head>
    <body>

    <button class="top-home-btn" onclick="window.location.href='landingPage.html'">HOME</button>

    <div class="container">
        <h1>Login</h1>

        <form>
            <label>USERNAME</label>
            <input type="text">

            <label>PASSWORD</label>
            <input type="password">

            <button>Login</button>
        </form>
    </div>

</body>
</html>
